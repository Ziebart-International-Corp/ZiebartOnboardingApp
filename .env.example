# Copy this to .env and fill in real values. Never commit .env to git.
# This app uses SQL Server only (DATABASE_URL / Neon is not used).

SECRET_KEY=your-secret-key-here

# Database (SQL Server) — required
DB_SERVER=your-server.com
DB_PORT=42278
DB_NAME=NewHireApp
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Optional
# DB_MAX_POOL_SIZE=300
