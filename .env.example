# --- Database: use ONE of the two below ---

# Option A: Neon (PostgreSQL) — for Vercel and/or local. Get URL from https://neon.tech
# If set, the app uses Neon and ignores DB_* below.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Option B: SQL Server (ZiebartOnboarding on iBartConnect) — for local / IIS
DB_SERVER=iBartConnect.com
DB_PORT=42278
DB_NAME=ZiebartOnboarding
DB_USER=developer2
DB_PASSWORD=NonagonInfinity@OpensTheDoor!

# Required for production
SECRET_KEY=your-secret-key-change-in-production

# Optional: mail (leave empty to disable)
# MAIL_SERVER=
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=

# Optional: app
# EMAIL_DOMAIN=ziebart.com