# Use direct Postgres (recommended for Vercel — no JWT required)
# Neon Console → Connect → copy connection string
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Or use Neon Data API (requires JWT from Neon Auth; leave unset to use DATABASE_URL)
# NEON_API_URL="https://ep-xxx.region.aws.neon.tech/neondb/rest/v1"
# NEON_API_KEY=""

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Optional: for seeding admin user (npm run db:seed)
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="ChangeMe123!"