# Neon Data API (REST) — no direct DB connection
# Dashboard: https://console.neon.tech → your project → Data API (or Connection details for API key)
NEON_API_URL="https://ep-xxx-xxx.region.aws.neon.tech/neondb/rest/v1"
NEON_API_KEY="your-neon-api-key"

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Optional: for seeding admin user (npm run db:seed)
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="ChangeMe123!"